{
  "name": "looky",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:generate": "dotenv -e .env.local -- node scripts/run-prisma.cjs generate",
    "db:push": "dotenv -e .env.local -- node scripts/run-prisma.cjs db push",
    "db:migrate": "dotenv -e .env.local -- node scripts/run-prisma.cjs migrate dev",
    "db:migrate:deploy": "dotenv -e .env.local -- node scripts/run-prisma.cjs migrate deploy",
    "db:seed": "node prisma/seed.cjs",
    "db:import": "dotenv -e .env.local -- node scripts/import-catalog.cjs",
    "db:studio": "dotenv -e .env.local -- node scripts/run-prisma.cjs studio"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@imgly/background-removal": "^1.7.0",
    "@mediapipe/tasks-vision": "^0.10.34",
    "@prisma/client": "6.19.2",
    "@radix-ui/react-icons": "^1.3.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.1",
    "@types/leaflet": "^1.9.21",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "next": "15.5.14",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-icons": "^5.6.0",
    "react-leaflet": "^5.0.0",
    "shadcn": "^4.1.1",
    "simplex-noise": "^4.0.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "prisma": {
    "seed": "node prisma/seed.cjs"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.14",
    "prisma": "6.19.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
