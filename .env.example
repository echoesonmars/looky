# Supabase (Dashboard → Project Settings → API)
# Без URL и anon key middleware на Vercel не падает — просто пропускает refresh (достаточно NextAuth + Prisma).
# URL: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# anon / public key (safe for client with RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional alias (Supabase dashboard “publishable” key name)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Postgres — Prisma (users/sessions). Auth is NextAuth + Credentials, not Supabase Auth.
# Prisma CLI: use npm run db:push / db:migrate (loads .env.local via dotenv-cli).
#
# If `Can't reach database server` / P1001 on db.*.supabase.co:5432 (firewall, ISP, region):
# Supabase → Project Settings → Database → Connection string → tab "Connection pooling"
# → use "Session pooler" or "Transaction pooler" URI (host *.pooler.supabase.com, port 6543).
# Append SSL if missing: ?sslmode=require  (or &sslmode=require after other params)
#
# Transaction pooler + Prisma: add &pgbouncer=true — see https://pris.ly/d/supabase-client
DATABASE_URL=

# If Prisma shows P1001 to db.*.supabase.co:5432 — required for `npm run db:push` from many networks:
# Dashboard → Database → Connection string → Connection pooling → Session pooler → paste here.
# DATABASE_POOLER_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require"
#
# Or replace DATABASE_URL above with that pooler URI only (no separate DATABASE_POOLER_URL).

# NextAuth / Auth.js — generate: openssl rand -base64 32
AUTH_SECRET=

# Optional in production — app URL (e.g. https://looky.example.com)
# AUTH_URL=

# Open-Meteo: запасные координаты, если пользователь не дал геолокацию в браузере (главная /home).
# LOOKY_WEATHER_LAT=55.7558
# LOOKY_WEATHER_LON=37.6173
