# Supabase (Dashboard → Project Settings → API)
# URL: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# anon / public key (safe for client with RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Postgres (Supabase → Project Settings → Database → Connection string → URI)
# Used by Prisma for users/sessions. Auth is NextAuth + Credentials, not Supabase Auth.
DATABASE_URL=

# NextAuth / Auth.js — generate: openssl rand -base64 32
AUTH_SECRET=

# Optional in production — app URL (e.g. https://looky.example.com)
# AUTH_URL=
