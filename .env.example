# Supabase (Dashboard → Project Settings → API)
# Без URL и anon key middleware на Vercel не падает — просто пропускает refresh (достаточно NextAuth + Prisma).
# URL: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# anon / public key (safe for client with RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional alias (Supabase dashboard “publishable” key name)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Postgres — Prisma (users/sessions). Auth is NextAuth + Credentials, not Supabase Auth.
# Prisma CLI: npm run db:migrate (dev) | npm run db:migrate:deploy (CI/Vercel) | npm run db:push
# Сид каталога для ленты: npm run db:seed (после миграций).
#
# If `Can't reach database server` / P1001 on db.*.supabase.co:5432 (firewall, ISP, region):
# Supabase → Project Settings → Database → Connection string → tab "Connection pooling"
# → use "Session pooler" or "Transaction pooler" URI (host *.pooler.supabase.com, port 6543).
# Append SSL if missing: ?sslmode=require  (or &sslmode=require after other params)
#
# Transaction pooler + Prisma: add &pgbouncer=true — see https://pris.ly/d/supabase-client
DATABASE_URL=

# If Prisma shows P1001 to db.*.supabase.co:5432 — required for `npm run db:push` from many networks:
# Dashboard → Database → Connection string → Connection pooling → Session pooler → paste here.
# DATABASE_POOLER_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require"
#
# Or replace DATABASE_URL above with that pooler URI only (no separate DATABASE_POOLER_URL).

# NextAuth / Auth.js — generate: openssl rand -base64 32
AUTH_SECRET=

# Optional in production — app URL (e.g. https://looky.example.com)
# AUTH_URL=

# Open-Meteo: запасные координаты, если пользователь не дал геолокацию в браузере (главная /home).
# LOOKY_WEATHER_LAT=55.7558
# LOOKY_WEATHER_LON=37.6173

# --- Гардероб: фото → HF → OpenAI + Supabase Storage ---
# Hugging Face: только на сервере (маршрут /api/hf-detect). Из браузера к HF нельзя — CORS; токен не в NEXT_PUBLIC_*.
# Токен: hf.co/settings/tokens — fine-grained с правом «Make calls to Inference Providers» (или классический read).
# Старый хост api-inference.huggingface.co отключён/deprecated; по умолчанию используется router (см. код).
HF_INFERENCE_TOKEN=
# Редко нужно: другой базовый URL object-detection (без завершающего /). По умолчанию https://router.huggingface.co/hf-inference
# HF_INFERENCE_API_BASE=https://router.huggingface.co/hf-inference
# Опционально переопределить модель на сервере (иначе NEXT_PUBLIC_HF_DETECT_MODEL не читается в API).
# HF_DETECT_MODEL=facebook/detr-resnet-50
# Модель в query из клиента (публично): тот же slug, что в HF.
NEXT_PUBLIC_HF_DETECT_MODEL=facebook/detr-resnet-50
NEXT_PUBLIC_HF_MIN_SCORE=0.7
# Список лейблов через запятую, lowercase (под COCO: tie,handbag,backpack,suitcase).
NEXT_PUBLIC_HF_ALLOWED_LABELS=tie,handbag,backpack,suitcase

# OpenAI: только сервер, маршрут /api/analyze-clothing (gpt-4o-mini + vision, JSON).
OPENAI_API_KEY=

# Supabase: service role — загрузка в Storage из API (не публикуйте в клиент).
# Где взять: Dashboard → Project Settings → API → «Project API keys» → service_role (Reveal / Copy).
# Не путать с anon: service_role только в .env.local / серверные env, никогда в NEXT_PUBLIC_*.
# Bucket `wardrobe`: для отображения фото в приложении URL из getPublicUrl должен отдавать 200 в браузере.
# Обычно bucket делают Public, либо настраивают политику чтения; иначе картинки в гардеробе будут битыми (403).
SUPABASE_SERVICE_ROLE_KEY=

# Replicate — Virtual Try-On (IDM-VTON cloud inference, no local GPU needed)
# Get your token at: https://replicate.com/account/api-tokens
# Used server-side only in /api/tryon — never exposed to the client.
REPLICATE_API_TOKEN=

#
# Почему в примере нет «S3 Access key / Secret» из Supabase Dashboard → Storage:
# это приложение не вызывает S3 API напрямую. Достаточно NEXT_PUBLIC_SUPABASE_URL + ключи API (anon)
# и SUPABASE_SERVICE_ROLE_KEY — маршрут /api/analyze-clothing пишет в бакет через supabase-js (.upload).
# Пара Access key ID + Secret + endpoint вида https://<ref>.storage.supabase.co/storage/v1/s3 нужна
# только внешним инструментам (AWS CLI, rclone, Terraform). Для Looky их в .env не добавляйте — код их не читает.
